/*******************************************************************************
 * Ops Table
 *******************************************************************************/

/**
 * @brief Default pin operations
 *
 * Users can either:
 *  1. Use this default implementation (after filling TODOs)
 *  2. Provide their own custom ops table
 */
static const st7735_pin_ops_t st7735_pin_ops =
{
    .cs_pin_low     = ctl_cs_pin_low,
    .cs_pin_high    = ctl_cs_pin_high,
    .dc_pin_low     = ctl_dc_pin_low,
    .dc_pin_high    = ctl_dc_pin_high,
    .reset_pin_low  = ctl_reset_pin_low,
    .reset_pin_high = ctl_reset_pin_high,
};

/*******************************************************************************
 * Public API
 *******************************************************************************/

/**
 * @brief Get default pin operations
 */
const st7735_pin_ops_t *get_st7735_pin_ops(void)
{
    return &st7735_pin_ops;
}

/**
 * @brief Initialize pin interface
 *
 * @param st7735_pin Pointer to pin handle
 * @param ops        Operations table (can be NULL to use default)
 *
 * @return 0 on success, negative on error
 */
int st7735_pin_init(st7735_pin_t *st7735_pin,
                    const st7735_pin_ops_t *ops)
{
    if (st7735_pin == NULL)
        return -1;

    if (ops == NULL)
    {
        /* Use default ops */
        st7735_pin->ops = &st7735_pin_ops;
    }
    else
    {
        st7735_pin->ops = ops;
    }

    return 0;
}

