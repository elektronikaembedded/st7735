/*******************************************************************************
 * @file        st7735_pin.c.example
 * @brief       ST7735 GPIO control template
 *
 * @details
 * This file provides a template implementation of the ST7735 pin interface.
 *
 * Copy this file to your project:
 *   port/st7735_pin/st7735_pin_<platform>.c
 *
 * Then update the GPIO control functions using your platform SDK
 * (STM32 HAL, ESP-IDF, Zephyr, etc.).
 *
 * Example:
 *   - STM32  -> HAL_GPIO_WritePin()
 *   - ESP32  -> gpio_set_level()
 ******************************************************************************/

/*******************************************************************************
 * Includes
 *******************************************************************************/
#include "st7735_pin.h"

/*******************************************************************************
 * User Configuration
 *******************************************************************************/
/*
 * Replace these macros or implement direct GPIO calls depending on your platform
 *
 * Example (STM32):
 *   #define ST7735_CS_PORT   GPIOB
 *   #define ST7735_CS_PIN    GPIO_PIN_0
 *
 * Example (ESP32):
 *   #define ST7735_CS_GPIO   5
 */

/*******************************************************************************
 * Static Functions (GPIO Control)
 *******************************************************************************/

